# Copy this file to .env and fill in your own values.
# Never commit real secrets or access tokens.

# OpenAI
OPENAI_API_KEY=sk-...
AGENT_MODEL=gpt-4o-mini
REVIEW_AGENT_MODEL=gpt-4o-mini

# Content generation
NEWS_COUNT=5
SECONDS_PER_SLIDE=8.0
TIKTOK_ACCOUNT_NAME=german.news69

# Optional: override RSS sources.
# Format: Name|URL;Name|URL
RSS_FEEDS=heise online|https://www.heise.de/newsticker/heise-atom.xml;Golem.de|https://rss.golem.de/rss.php?feed=RSS2.0

# TikTok OAuth / draft upload
UPLOAD_TO_TIKTOK=true
TIKTOK_REFRESH_TOKEN=...
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...
TIKTOK_REDIRECT_URI=https://ikayou.github.io/tiktok-api-legal/
TIKTOK_SCOPES=user.info.basic,video.upload,video.publish

# Optional, only for temporary one-off TikTok scripts.
TIKTOK_ACCESS_TOKEN=
TIKTOK_UPLOAD_STATUS_TIMEOUT_SEC=900
TIKTOK_UPLOAD_STATUS_POLL_INTERVAL_SEC=10
TIKTOK_UPLOAD_STATUS_TIMEOUT_IS_ERROR=false

# Instagram carousel publishing
UPLOAD_TO_INSTAGRAM=true
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_USER_ID=...
# Alternative to INSTAGRAM_USER_ID:
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_API_VERSION=v24.0
INSTAGRAM_GRAPH_HOST=graph.facebook.com
INSTAGRAM_MAX_CAROUSEL_ITEMS=10
INSTAGRAM_JPEG_QUALITY=95
INSTAGRAM_PROCESSING_TIMEOUT_SEC=900
INSTAGRAM_PROCESSING_POLL_INTERVAL_SEC=10

# Public image hosting for Instagram carousel images.
# Local WSL example:
GITHUB_SLIDES_REPO=git@github.com:your-user/instagram-slides.git
GITHUB_SLIDES_DIR=/home/your-user/instagram-slides
GITHUB_SLIDES_BRANCH=main
GITHUB_PAGES_BASE_URL=https://your-user.github.io/instagram-slides

# GitHub Actions secret name: SLIDES_REPO_URL.
# The workflow maps SLIDES_REPO_URL to this GITHUB_SLIDES_REPO env var.
# Optional for GitHub Actions HTTPS pushes to GITHUB_SLIDES_REPO.
GITHUB_TOKEN=
GIT_COMMITTER_NAME=github-actions[bot]
GIT_COMMITTER_EMAIL=github-actions[bot]@users.noreply.github.com
